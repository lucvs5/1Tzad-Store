// backend/prisma/schema.prisma - CONFIGURAÇÃO DO BANCO

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Definimos SQLite por enquanto
  url      = env("DATABASE_URL")
}

// Tabela de Usuários (Login)
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  phone     String?
  orders    Order[]
}

// Tabela de Pedidos
model Order {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  total           Float
  status          String   @default("Pendente")
  telegramMsgId   String?  // ID da mensagem no Canal para podermos responder
  createdAt       DateTime @default(now())
}
